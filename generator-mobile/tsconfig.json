{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true, // Active toutes les vérifications de type strictes
    "esModuleInterop": true, // Permet d'importer des modules CommonJS comme des modules ES6
    "skipLibCheck": true, // Accélère la compilation en sautant la vérification des bibliothèques tierces
    "baseUrl": ".", // Définit la racine pour les imports absolus
    "paths": {
      "@/*": ["./src/*"] // Permet d'importer des fichiers avec "@/" au lieu de "../../"
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}